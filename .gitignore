# Site config and secrets are local-only
# Use *.example as starting templates
site.yaml
secrets.yaml
secrets.yaml.enc

# Site-specific configs (generated per-deployment via make host-config, make node-config)
hosts/*.yaml
nodes/*.yaml

# Per-host TLS certificates (generated by server daemon)
tls/

# Legacy runtime state (moved to $HOMESTAK_ROOT/.state/config/ in v0.56)
.state/

# Editor files
*.swp
*~
.idea/
.vscode/

# Claude Code local settings
.claude/settings.local.json

# OS files
.DS_Store
